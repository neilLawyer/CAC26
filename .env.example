# HUD PD&R API token — free, required for local rent benchmarks (FMR) and income limits (IL).
# Register at https://www.huduser.gov/portal/dataset/fmr-api.html then paste the token here
# in your own .env.local (NEVER commit .env.local).
HUD_TOKEN=

# Optional accounts (save results across devices) — auto-populated by
# `vercel integration add clerk` / `vercel integration add neon` (see README's
# "Optional accounts" section). Without these, the guest screener flow works
# unaffected; only sign-in/sign-up and the save button need them.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
DATABASE_URL=
